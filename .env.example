# ════════════════════════════════════════════════════════════
#  email-automation — .env.example
#  Copy this to .env and fill in your real values.
#  NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════

# ── SMTP (Gmail recommended) ──────────────────────────────────
# For Gmail: enable 2FA, then generate an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# ── Sender identity ───────────────────────────────────────────
SENDER_NAME=Vishal Raina
SENDER_EMAIL=your_gmail@gmail.com

# ── Email subject ({{name}} and {{company}} are substituted) ──
EMAIL_SUBJECT=Exploring Backend Developer Opportunities at {{company}}

# ── Template file path (relative to project root) ────────────
TEMPLATE_FILE=templates/cold_email.txt

# ── Rate limiting ─────────────────────────────────────────────
DELAY_MIN_SECONDS=10
DELAY_MAX_SECONDS=30
MAX_EMAILS_PER_RUN=50
MAX_RETRIES=3
RETRY_DELAY_SECONDS=60

# ── AI Personalization (optional) ────────────────────────────
# Set USE_AI_PERSONALIZATION=true to enable OpenAI rewriting.
# Each email will be uniquely rephrased — costs ~$0.001/email.
USE_AI_PERSONALIZATION=false
OPENAI_API_KEY=sk-...your_openai_key...
OPENAI_MODEL=gpt-4o-mini

# ── Open tracking (optional) ─────────────────────────────────
# Point this at your own pixel endpoint.
# It will receive GET requests with ?email=<address>
# Leave blank to disable.
TRACKING_PIXEL_URL=
